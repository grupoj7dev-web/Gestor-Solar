# Solplanet - Monitoramento
# Checklist de ativacao real:
# 1) Preencher APP_KEY/APP_SECRET e (se fornecido) TOKEN
# 2) Ajustar endpoint oficial de usinas em SOLPLANET_MONITOR_STATIONS_ENDPOINT
# 3) Trocar SOLPLANET_MONITOR_MOCK para false
# 4) Reiniciar backend
SOLPLANET_MONITOR_BASE_URL=https://internation-pro-cloud.solplanet.net
SOLPLANET_MONITOR_APP_KEY=REPLACE_WITH_SOLPLANET_APP_KEY
SOLPLANET_MONITOR_APP_SECRET=REPLACE_WITH_SOLPLANET_APP_SECRET
SOLPLANET_MONITOR_USERNAME=REPLACE_WITH_SOLPLANET_USERNAME
SOLPLANET_MONITOR_PASSWORD=REPLACE_WITH_SOLPLANET_PASSWORD
SOLPLANET_MONITOR_TOKEN=
SOLPLANET_MONITOR_MOCK=true
SOLPLANET_MONITOR_LOGIN_ENDPOINT=/api/login
SOLPLANET_MONITOR_LOGIN_METHOD=POST
SOLPLANET_MONITOR_LOGIN_BODY_USER_FIELD=username
SOLPLANET_MONITOR_LOGIN_BODY_PASS_FIELD=password
SOLPLANET_MONITOR_TOKEN_FIELD=token
SOLPLANET_MONITOR_TOKEN_HEADER=Authorization
SOLPLANET_MONITOR_TOKEN_PREFIX=Bearer 
SOLPLANET_MONITOR_STATIONS_ENDPOINT=/monitoring/stations

# TSUNESS
# Checklist de ativacao real:
# 1) Preencher API_KEY/API_SECRET e (se fornecido) TOKEN
# 2) Ajustar endpoint oficial de usinas em TSUNESS_STATIONS_ENDPOINT
# 3) Trocar TSUNESS_MOCK para false
# 4) Reiniciar backend
TSUNESS_BASE_URL=https://api.tsuness.com
TSUNESS_API_KEY=REPLACE_WITH_TSUNESS_API_KEY
TSUNESS_API_SECRET=REPLACE_WITH_TSUNESS_API_SECRET
TSUNESS_USERNAME=REPLACE_WITH_TSUNESS_USERNAME
TSUNESS_PASSWORD=REPLACE_WITH_TSUNESS_PASSWORD
TSUNESS_TOKEN=
TSUNESS_MOCK=true
TSUNESS_STATIONS_ENDPOINT=/monitoring/stations

# iSolarCloud (Sungrow)
ISOLARCLOUD_BASE_URL=https://gateway.isolarcloud.com
ISOLARCLOUD_APP_KEY=REPLACE_WITH_ISOLARCLOUD_APP_KEY
