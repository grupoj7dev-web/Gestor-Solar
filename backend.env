ISOLARCLOUD_LOGIN_BODY_USER_FIELD=userName
ISOLARCLOUD_LOGIN_BODY_PASS_FIELD=password
ISOLARCLOUD_TOKEN_FIELD=token
ISOLARCLOUD_TOKEN_HEADER=Authorization
ISOLARCLOUD_TOKEN_PREFIX=Bearer 
ISOLARCLOUD_STATIONS_ENDPOINT=/openapi/powerStation/list

