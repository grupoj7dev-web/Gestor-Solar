# Solarman API
SOLARMAN_BASE_URL=https://globalapi.solarmanpv.com
SOLARMAN_APP_ID=REPLACE_WITH_NEW_APP_ID
SOLARMAN_APP_SECRET=REPLACE_WITH_NEW_APP_SECRET
SOLARMAN_ORG_ID=
SOLARMAN_EMAIL=
SOLARMAN_USERNAME=
SOLARMAN_MOBILE=
SOLARMAN_PASSWORD=REPLACE_WITH_NEW_SOLARMAN_PASSWORD
SOLARMAN_TOKEN_CACHE=var/token.json

# Solis API
SOLIS_BASE_URL=https://www.soliscloud.com:13333
SOLIS_API_ID=REPLACE_WITH_SOLIS_API_ID
SOLIS_API_SECRET=REPLACE_WITH_SOLIS_API_SECRET
SOLIS_STATION_ID=

# Deye API
DEYE_BASE_URL=https://us1-developer.deyecloud.com/v1.0
DEYE_APP_ID=REPLACE_WITH_DEYE_APP_ID
DEYE_APP_SECRET=REPLACE_WITH_DEYE_APP_SECRET
DEYE_EMAIL=
DEYE_USERNAME=
DEYE_MOBILE=
DEYE_COUNTRY_CODE=
DEYE_PASSWORD=REPLACE_WITH_DEYE_PASSWORD
DEYE_COMPANY_ID=
DEYE_TOKEN_CACHE=var/deye-token.json

# Server
PORT=4001
JWT_SECRET=REPLACE_WITH_A_STRONG_RANDOM_SECRET

# AI providers
GEMINI_API_KEY=REPLACE_WITH_GEMINI_API_KEY
ELEVENLABS_API_KEY=REPLACE_WITH_NEW_ELEVENLABS_API_KEY

# Prisma
DATABASE_URL="file:./dev.db"
GEMINI_MODEL=gemini-2.5-flash

# AI Vision cost controls
AI_VISION_INSIGHTS_TTL_MS=300000
AI_VISION_PDF_AI_LIMIT=12
AI_VISION_PDF_AI_CONCURRENCY=2
